# ============================================================================
# asmltr — environment configuration
# Copy to .env (gitignored). Loaded by every entrypoint via shared/loadenv.js.
# Real environment / PM2 env take precedence over this file.
# ============================================================================

# --- Assistant identity -----------------------------------------------------
# Name used in prompts, channel-awareness, and the Discord voice wake word.
ASSISTANT_NAME=Assistant

# --- Secrets provider -------------------------------------------------------
# A "secret key" (e.g. openai_api_key, discord_bot_token) resolves in this order:
#   1. process.env[key] / process.env[UPPER_SNAKE(key)]
#   2. JSON file at ASMLTR_SECRETS_FILE  ({ "key": "value" })
#   3. Command at ASMLTR_SECRET_CMD      ({key} is replaced with the key)
# Pick ONE approach. Simplest = put the secrets below directly in this file.
# ASMLTR_SECRETS_FILE=/path/to/secrets.json
# ASMLTR_SECRET_CMD=vault-read {key}          # e.g. a Bitwarden/Vault wrapper

# Secrets consumed by the core + connectors (env-var form shown):
OPENAI_API_KEY=            # moderation + Discord voice speech-to-text
ELEVENLABS_API_KEY=        # Discord voice text-to-speech (optional)
DISCORD_BOT_TOKEN=         # referenced by the discord instance's bot_token_bws_key
TELEGRAM_BOT_TOKEN=        # referenced by the telegram instance's bot_token_bws_key
# GitHub PAT is referenced per-instance via pat_bws_key (e.g. MY_GITHUB_PAT=...)

# --- Ports (bind 127.0.0.1; front with a reverse proxy for anything public) -
ASMLTR_CORE_PORT=3023
ASMLTR_MANAGER_PORT=3024
ASMLTR_INSIGHTS_PORT=3017

# --- Inter-service URLs (defaults match the ports above) --------------------
# ASMLTR_CORE_URL=http://127.0.0.1:3023/v2/handle
# ASMLTR_COLLECTOR_URL=http://127.0.0.1:3017/ingest

# --- Access tokens (set before exposing any service beyond localhost) -------
# ASMLTR_MANAGER_TOKEN=
# ASMLTR_INSIGHTS_TOKEN=

# --- Admin/security alert hook ----------------------------------------------
# Runs on moderation errors + blocked requests. {msg} = the alert text. No-op if unset.
# ASMLTR_ADMIN_ALERT_CMD=notify-admin {msg}

# --- Data locations (sensible defaults if unset) ----------------------------
# ASMLTR_GITHUB_WORKSPACE=~/.asmltr/github-repos     # github clone workspace
# ASMLTR_MCP_CLIENTS_FILE=connectors/types/mcp/clients.json
# ASMLTR_TRUST_SEED=core/src/trust/seed.json

# --- Optional collector integrations (off by default) -----------------------
# ASMLTR_ENABLE_TAILER=1
# ASMLTR_TRACKER_PATH=/path/to/session-tracker.json
# ASMLTR_QUERY_LOG_DIR=/path/to/query-logs
# ASMLTR_MOD_LOG_DIR_SRC=/path/to/moderation-logs

# --- MCP connector (only if you run the mcp type) ---------------------------
# BASE_URL=https://mcp.example.com     # public issuer URL for OAuth metadata
# TOKEN_EXPIRY_HOURS=720
