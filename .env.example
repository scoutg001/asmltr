# ============================================================================
# asmltr — environment configuration
# Copy to .env (gitignored). Loaded by every entrypoint via shared/loadenv.js.
# Real environment / PM2 env take precedence over this file.
# ============================================================================

# --- Assistant identity -----------------------------------------------------
# Name used in prompts, channel-awareness, and the Discord voice wake word.
ASSISTANT_NAME=Assistant

# Terminal multiplexer for interactive `asmltr claude` sessions: tmux (default) or screen.
# screen keeps output in the terminal's main buffer, so the native mouse wheel scrolls scrollback
# (tmux owns the alt-screen and needs copy-mode). Whichever is chosen must be installed.
# ASMLTR_MULTIPLEXER=tmux

# Identity + startup context for interactive `asmltr claude` sessions (the "Likeness" plane).
# The session's --append-system-prompt is: an IDENTITY anchor (name + optional self-description) +
# your own pluggable CONTEXT + the asmltr toolbelt note. Set ASMLTR_SELF_AWARE=off to disable it all.
# ASMLTR_IDENTITY_FILE=~/.asmltr/identity.md          # canonical self-description (who you are)
# ASMLTR_CLAUDE_CONTEXT_CMD=                          # a command; its stdout is injected as context
# ASMLTR_CONTEXT_DIR=~/.asmltr/context.d              # dir of executables; each stdout injected (sorted)
#   → each context source runs with ASMLTR_CWD set, so it can adapt to the working directory.

# Agent model for channel turns (rides the Claude subscription via @anthropic-ai/claude-agent-sdk).
# An alias (opus/sonnet) auto-tracks the latest of that tier; a full id pins exactly; unset = the
# SDK default (currently the 1M-context Opus). NOTE: the modern CLI needs IS_SANDBOX=1 to permit
# autonomous (bypassPermissions) operation as root — the core sets that for you.
ASMLTR_MODEL=opus

# --- Secrets provider -------------------------------------------------------
# A "secret key" (e.g. openai_api_key, discord_bot_token) resolves in this order:
#   1. process.env[key] / process.env[UPPER_SNAKE(key)]
#   2. JSON file at ASMLTR_SECRETS_FILE  ({ "key": "value" })
#   3. Command at ASMLTR_SECRET_CMD      ({key} is replaced with the key)
# Pick ONE approach. Simplest = put the secrets below directly in this file.
# ASMLTR_SECRETS_FILE=/path/to/secrets.json
# ASMLTR_SECRET_CMD=vault-read {key}          # e.g. a Bitwarden/Vault wrapper

# Secrets consumed by the core + connectors (env-var form shown):
OPENAI_API_KEY=            # moderation + text-to-speech + speech-to-text (dashboard voice + Discord)
ELEVENLABS_API_KEY=        # Discord voice text-to-speech (optional)
DISCORD_BOT_TOKEN=         # referenced by the discord instance's bot_token_bws_key
TELEGRAM_BOT_TOKEN=        # referenced by the telegram instance's bot_token_bws_key
# GitHub PAT is referenced per-instance via pat_bws_key (e.g. MY_GITHUB_PAT=...)

# --- Voice (dashboard read-aloud + dictation; also /v2/speak). Defaults shown; the GUI/TUI
#     Settings > Voice tab overrides voice/model at runtime (persisted, no restart). ------------
# ASMLTR_TTS_PROVIDER=openai         # text-to-speech provider
# ASMLTR_TTS_VOICE=alloy             # default spoken voice
# ASMLTR_TTS_MODEL=tts-1             # tts-1 | tts-1-hd | gpt-4o-mini-tts
# ASMLTR_STT_PROVIDER=openai         # speech-to-text provider (transcription)
# ASMLTR_STT_MODEL=gpt-4o-transcribe # gpt-4o-transcribe | gpt-4o-mini-transcribe | whisper-1
# ASMLTR_STT_LANGUAGE=en             # ISO-639-1 hint; empty = auto-detect

# --- Ports (bind 127.0.0.1; front with a reverse proxy for anything public) -
ASMLTR_CORE_PORT=3023
ASMLTR_MANAGER_PORT=3024
ASMLTR_INSIGHTS_PORT=3017

# --- Inter-service URLs (defaults match the ports above) --------------------
# ASMLTR_CORE_URL=http://127.0.0.1:3023/v2/handle
# ASMLTR_COLLECTOR_URL=http://127.0.0.1:3017/ingest

# --- Access tokens (set before exposing any service beyond localhost) -------
# ASMLTR_MANAGER_TOKEN=
# ASMLTR_INSIGHTS_TOKEN=

# --- Web chat (the dashboard as a browser connector) ------------------------
# The dashboard can start/drive sessions itself (channel `eve-assistant-web`). It never
# hardcodes who the operator is — the core resolves the sender identity from this value, or
# (if unset) from the reverse proxy's Authelia-resolved `X-Remote-User` header. Set it to the
# trust identifier of whoever the dashboard is gated to (must resolve to a trusted principal).
# ASMLTR_WEB_OWNER_ID=owner

# --- Admin/security alerts (fired on moderation errors + blocked requests) --
# Configure ANY of these (each one that's set fires); leave all unset to disable.
# Option A — route through a connector you've already configured (uses the manager's
#   /send; the connector must advertise outbound, e.g. discord/telegram). JSON or shorthand:
#     ASMLTR_ADMIN_ALERT_SEND={"channel":"discord","target":"<channelId>"}
#     ASMLTR_ADMIN_ALERT_SEND=telegram              # the telegram instance's default chat
#     ASMLTR_ADMIN_ALERT_SEND=discord|<channelId>   # a specific discord channel
# Option B — a shell command ({msg} = the alert text); good for email/webhooks/custom scripts.
#     ASMLTR_ADMIN_ALERT_CMD=notify-admin {msg}
# Only if the connector route is used and the manager isn't on the default host/port (or has a token):
# ASMLTR_MANAGER_URL=http://127.0.0.1:3024
# ASMLTR_MANAGER_TOKEN=

# --- Moderation (LLM security screen run on every inbound message) ----------
# Provider, model, and key are all configurable. Default: OpenAI.
# ASMLTR_MODERATION_PROVIDER=openai            # openai | anthropic
# ASMLTR_MODERATION_MODEL=gpt-5-nano           # e.g. claude-haiku-4-5-20251001 for anthropic
# ASMLTR_MODERATION_KEY=openai_api_key         # secret KEY NAME (default: openai_api_key / anthropic_api_key)
# NOTE: for the anthropic provider, store the key via ASMLTR_SECRETS_FILE or ASMLTR_SECRET_CMD —
# do NOT set ANTHROPIC_API_KEY (the core strips it so agent execution stays on the subscription).
# Full details: docs/MODERATION.md

# --- Data locations (sensible defaults if unset) ----------------------------
# ASMLTR_GITHUB_WORKSPACE=~/.asmltr/github-repos     # github clone workspace
# ASMLTR_MCP_CLIENTS_FILE=connectors/types/mcp/clients.json
# ASMLTR_TRUST_SEED=core/src/trust/seed.json

# --- Optional collector integrations (off by default) -----------------------
# ASMLTR_ENABLE_TAILER=1
# ASMLTR_TRACKER_PATH=/path/to/session-tracker.json
# ASMLTR_QUERY_LOG_DIR=/path/to/query-logs
# ASMLTR_MOD_LOG_DIR_SRC=/path/to/moderation-logs

# --- MCP connector (only if you run the mcp type) ---------------------------
# BASE_URL=https://mcp.example.com     # public issuer URL for OAuth metadata
# TOKEN_EXPIRY_HOURS=720

# Shared upload surface — where inbound files from ALL channels are stored + indexed
# (manifest.jsonl lives here). Default: ~/.asmltr/uploads
# ASMLTR_UPLOADS_DIR=/path/to/uploads
